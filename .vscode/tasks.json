{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Terraform Init",
      "type": "shell",
      "command": "terraform init",
      "options": {
        "cwd": "${workspaceFolder}/terraform/environments/dev"
      },
      "group": "build"
    },
    {
      "label": "Terraform Plan",
      "type": "shell",
      "command": "terraform plan -out=tfplan",
      "options": {
        "cwd": "${workspaceFolder}/terraform/environments/dev"
      },
      "group": "build"
    },
    {
      "label": "Terraform Apply",
      "type": "shell",
      "command": "terraform apply tfplan",
      "options": {
        "cwd": "${workspaceFolder}/terraform/environments/dev"
      },
      "group": "build"
    },
    {
      "label": "Python Test",
      "type": "shell",
      "command": "python -m pytest",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test"
    }
  ]
}
